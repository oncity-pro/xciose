# ONCITY-Django API 测试示例
# 使用 httpie 或 curl 进行测试

# ============================================
# 1. 健康检查
# ============================================

# 使用 httpie
http GET http://127.0.0.1:8000/api/health/

# 使用 curl
curl -X GET http://127.0.0.1:8000/api/health/

# 预期响应:
# {
#   "status": "healthy",
#   "message": "ONCITY Django Backend is running",
#   "version": "1.0.0"
# }


# ============================================
# 2. 获取样本列表
# ============================================

# 使用 httpie
http GET http://127.0.0.1:8000/api/v1/samples/

# 使用 curl
curl -X GET http://127.0.0.1:8000/api/v1/samples/

# 预期响应:
# {
#   "count": 0,
#   "next": null,
#   "previous": null,
#   "results": []
# }


# ============================================
# 3. 创建样本
# ============================================

# 使用 httpie
http POST http://127.0.0.1:8000/api/v1/samples/ \
    title="第一个测试样本" \
    description="这是一个测试描述" \
    is_active:=true

# 使用 curl
curl -X POST http://127.0.0.1:8000/api/v1/samples/ \
    -H "Content-Type: application/json" \
    -d '{
        "title": "第一个测试样本",
        "description": "这是一个测试描述",
        "is_active": true
    }'

# 预期响应:
# {
#   "id": 1,
#   "title": "第一个测试样本",
#   "description": "这是一个测试描述",
#   "created_at": "2026-04-21T08:00:00Z",
#   "updated_at": "2026-04-21T08:00:00Z",
#   "is_active": true
# }


# ============================================
# 4. 获取单个样本详情
# ============================================

# 使用 httpie
http GET http://127.0.0.1:8000/api/v1/samples/1/

# 使用 curl
curl -X GET http://127.0.0.1:8000/api/v1/samples/1/


# ============================================
# 5. 更新样本（完整更新）
# ============================================

# 使用 httpie
http PUT http://127.0.0.1:8000/api/v1/samples/1/ \
    title="更新后的标题" \
    description="更新后的描述" \
    is_active:=false

# 使用 curl
curl -X PUT http://127.0.0.1:8000/api/v1/samples/1/ \
    -H "Content-Type: application/json" \
    -d '{
        "title": "更新后的标题",
        "description": "更新后的描述",
        "is_active": false
    }'


# ============================================
# 6. 部分更新样本
# ============================================

# 使用 httpie
http PATCH http://127.0.0.1:8000/api/v1/samples/1/ \
    title="仅更新标题"

# 使用 curl
curl -X PATCH http://127.0.0.1:8000/api/v1/samples/1/ \
    -H "Content-Type: application/json" \
    -d '{
        "title": "仅更新标题"
    }'


# ============================================
# 7. 删除样本
# ============================================

# 使用 httpie
http DELETE http://127.0.0.1:8000/api/v1/samples/1/

# 使用 curl
curl -X DELETE http://127.0.0.1:8000/api/v1/samples/1/


# ============================================
# 8. 分页查询
# ============================================

# 获取第2页，每页5条
http GET http://127.0.0.1:8000/api/v1/samples/?page=2&page_size=5

# 使用 curl
curl -X GET "http://127.0.0.1:8000/api/v1/samples/?page=2&page_size=5"


# ============================================
# 9. 搜索和过滤
# ============================================

# 搜索标题包含"测试"的样本
http GET http://127.0.0.1:8000/api/v1/samples/?search=测试

# 过滤激活状态的样本
http GET http://127.0.0.1:8000/api/v1/samples/?is_active=true


# ============================================
# 安装 httpie (推荐用于测试)
# ============================================
# pip install httpie
